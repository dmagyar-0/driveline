# Claude Code agent worktrees (local scratch only)
.claude/worktrees/

# Rust
/target
**/*.rs.bk

# Node
node_modules
.pnpm-store
.pnpm-debug.log*

# Vite
apps/web/dist
apps/web/.vite

# TypeScript incremental build cache (`tsc -b` writes this next to the
# project's tsconfig.json).
*.tsbuildinfo

# wasm-pack output (generated; regenerate with `pnpm wasm:build`)
apps/web/src/wasm/*
!apps/web/src/wasm/.gitkeep

# Sample corpus (T0.3). Committed scripts, schemas, and small fixtures
# are tracked via explicit un-ignores below; large regenerated outputs
# (out.h264, short.mcap, short.mp4) are excluded by sample-data/.gitignore.
sample-data/*
!sample-data/.gitignore
!sample-data/README.md
!sample-data/generate.py
!sample-data/EXPECTED_HASHES.txt
!sample-data/short.mp4.timestamps
!sample-data/short.mf4
!sample-data/schemas/
!sample-data/refs/
# Real-world dataset converters write fixtures into sample-data/realworld/.
# Track the docs only; the generated .mcap regenerates from the public
# source via scripts/convert_comma2k19_to_mcap.py.
!sample-data/realworld/
sample-data/realworld/*
!sample-data/realworld/README.md

# Editor / OS
.DS_Store
.idea/
.vscode/

# Playwright
/apps/e2e/playwright-report
/apps/e2e/test-results
/test-results

# Recordings produced by `tests/_record-4k.spec.ts` — local diagnostic
# artefacts only, never committed.
/apps/e2e/recordings
