# Rust
/target
**/*.rs.bk

# Node
node_modules
.pnpm-store
.pnpm-debug.log*

# Vite
apps/web/dist
apps/web/.vite

# TypeScript incremental build cache (`tsc -b` writes this next to the
# project's tsconfig.json).
*.tsbuildinfo

# wasm-pack output. This is a generated build artefact, NOT committed: the
# `.wasm` is multi-MB and would bloat history. Regenerate with `pnpm wasm:build`
# (or `:dev`). `pnpm build` and CI build it before tsc/Vite. Only `.gitkeep`
# is tracked so the directory exists on a fresh checkout. (wasm-pack also
# drops its own `apps/web/src/wasm/.gitignore` containing `*`, which is
# consistent with this — the whole dir's contents stay untracked.)
apps/web/src/wasm/*
!apps/web/src/wasm/.gitkeep

# Sample corpus (T0.3). Committed scripts, schemas, and small fixtures
# are tracked via explicit un-ignores below; large regenerated outputs
# (out.h264, short.mcap, short.mp4) are excluded by sample-data/.gitignore.
sample-data/*
!sample-data/.gitignore
!sample-data/README.md
!sample-data/generate.py
!sample-data/generate_tabular.py
!sample-data/generate_acme.py
!sample-data/generate_calib_scene.py
!sample-data/sample.acme.recipe.json
!sample-data/sample.acme.agent-transcript.md
!sample-data/EXPECTED_HASHES.txt
!sample-data/short.mp4.timestamps
!sample-data/short.mf4
!sample-data/schemas/
!sample-data/refs/
# Real-world dataset converters write fixtures into sample-data/realworld/.
# Track the docs only; the generated .mcap regenerates from the public
# source via scripts/convert_comma2k19_to_mcap.py.
!sample-data/realworld/
sample-data/realworld/*
!sample-data/realworld/README.md
# OpenLABEL demo fixtures are small, static, externally-authored JSON (one
# synthetic dashcam scene + the real Vicomtech VCD cuboid example) — committed,
# not regenerated. Track the whole directory.
!sample-data/openlabel/
# Synthetic camera/LiDAR calibration fixture — small, deterministic, committed
# (point-cloud Parquet + projected camera MP4 + sidecar + calib JSON). Proves
# the point-cloud-on-video overlay lands on exact pixels. Regenerated by
# sample-data/generate_calib_scene.py; hashes pinned in EXPECTED_HASHES.txt.
!sample-data/calib/

# Editor / OS
.DS_Store
.idea/
.vscode/

# Playwright
/apps/e2e/playwright-report
/apps/e2e/test-results
/test-results

# Recordings produced by `tests/_record-4k.spec.ts` — local diagnostic
# artefacts only, never committed.
/apps/e2e/recordings

# Stitched "Bring Your Own Agent" screencast from
# `scripts/record-byoa-demo.sh` — multi-MB generated artefact, regenerate
# locally rather than committing.
/demo

# Driveline point-cloud Parquet emitted by `tools/alpamayo_lidar_to_driveline.py`
# — multi-MB generated demo data (like the wasm bundle), never committed.
*.lidar.parquet
# ...except the small committed synthetic calibration fixture (see above).
!sample-data/calib/scene.lidar.parquet

.claude/worktrees/
