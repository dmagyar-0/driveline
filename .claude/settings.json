{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push)",
      "Bash(git push -u origin *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git fetch *)",
      "Bash(git pull *)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git switch *)",
      "Bash(git restore *)",
      "Bash(git rev-parse *)",
      "Bash(git remote *)",
      "Bash(git stash *)",
      "Bash(git config --get *)",
      "Bash(pnpm install)",
      "Bash(pnpm install *)",
      "Bash(pnpm test *)",
      "Bash(pnpm run *)",
      "Bash(pnpm --filter *)",
      "Bash(pnpm exec *)",
      "Bash(npx playwright *)",
      "Bash(cargo build)",
      "Bash(cargo build *)",
      "Bash(cargo test)",
      "Bash(cargo test *)",
      "Bash(cargo check)",
      "Bash(cargo check *)",
      "Bash(cargo clippy)",
      "Bash(cargo clippy *)",
      "Bash(cargo fmt)",
      "Bash(cargo fmt *)",
      "Bash(make *)",
      "Bash(python3 *)"
    ]
  }
}
